#--------------------------------------------------------------------
# SWEET BAKERY - Environment Configuration
#--------------------------------------------------------------------

CI_ENVIRONMENT = development

#--------------------------------------------------------------------
# APP
#--------------------------------------------------------------------
app.baseURL = 'http://localhost:8080/'
app.indexPage = ''

#--------------------------------------------------------------------
# DATABASE
#--------------------------------------------------------------------
# Aplikasi ini memakai SQLite (file: writable/database/sweet_bakery.db).
# TIDAK perlu MySQL/phpMyAdmin. Konfigurasi diatur di app/Config/Database.php.
# (Baris database sengaja dikosongkan agar memakai setting SQLite di Database.php)

#--------------------------------------------------------------------
# SECURITY
#--------------------------------------------------------------------
security.csrfProtection = 'cookie'
security.tokenRandomize = false

encryption.key = hex2bin:85bd8f627a2dc613058a00d9f30184a7f2635cbab1247a4db09ac929ab536359
